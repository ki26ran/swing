[Unit]
Description=Swing Trading Dashboard
After=network.target

[Service]
Type=simple
User=root
WorkingDirectory=/opt/swing
Environment=APP_ENV=prod
ExecStartPre=-/usr/bin/pkill -f "streamlit.*swing" 2>/dev/null
ExecStart=/opt/swing/venv/bin/streamlit run app.py --server.address 0.0.0.0 --server.port 8502
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
